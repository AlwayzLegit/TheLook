{
  "crons": [
    {
      "path": "/api/cron/reminders",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/sync-reviews",
      "schedule": "0 9 * * *"
    }
  ],
  "headers": [
    {
      "source": "/images/hero/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
