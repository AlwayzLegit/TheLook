# Vercel Postgres (Neon) — auto-set when you add Postgres storage in Vercel dashboard
POSTGRES_URL=postgres://user:pass@host/db

# Resend Email (optional — booking works without it)
RESEND_API_KEY=re_your_api_key
RESEND_FROM_EMAIL=onboarding@resend.dev

# NextAuth
NEXTAUTH_SECRET=generate-a-random-32-char-string
NEXTAUTH_URL=http://localhost:3000

# Admin Credentials
ADMIN_EMAIL=look_hairsalon@yahoo.com
# Generate with: npm run hash-password -- 'your-password'
ADMIN_PASSWORD_HASH=$2b$12$replace_with_bcrypt_hash

# Cron Security
CRON_SECRET=generate-a-random-string

# Rate limiting (Upstash Redis REST). Optional locally; required in
# production to actually enforce limits. Without these, limiters are
# inert and a console.warn fires once.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: error reporting hook. Logger no-ops if unset.
SENTRY_DSN=
