# ============================================
# STAGING ENVIRONMENT CONFIGURATION
# ============================================

# Supabase PostgreSQL Connection (required for booking system)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
POSTGRES_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Alternative: If Supabase provides a different connection string format
DATABASE_URL=

# NextAuth Configuration (required for admin login)
NEXTAUTH_SECRET=your-random-secret-here-at-least-32-characters
NEXTAUTH_URL=http://localhost:3000

# Admin Credentials (required for admin dashboard access)
ADMIN_EMAIL=admin@thelook.com
ADMIN_PASSWORD=your-secure-password

# Resend Email API (required for booking confirmations & reminders)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# Cron Secret (required for automated reminder emails)
CRON_SECRET=your-cron-secret-here

# ============================================
# OPTIONAL / PRODUCTION OVERRIDES
# ============================================

# Optional: Cloudflare Turnstile (bot protection for booking/contact forms)
# If TURNSTILE_SECRET_KEY is set, token verification is enforced.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional: Upstash Redis REST (distributed rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
