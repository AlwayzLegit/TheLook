# ============================================
# REQUIRED: DATABASE
# ============================================

# Supabase PostgreSQL connection (used by Drizzle ORM for seeding/migrations)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
POSTGRES_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Alternative connection string (used if POSTGRES_URL is not set)
DATABASE_URL=

# Supabase client credentials (used by the app at runtime)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# Public aliases (Next.js exposes these to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# ============================================
# REQUIRED: AUTHENTICATION
# ============================================

# NextAuth secret for signing JWTs (min 32 characters)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here-at-least-32-characters
AUTH_SECRET=

# App URL (used for redirects and email links)
NEXTAUTH_URL=http://localhost:3000

# Primary admin login credentials
ADMIN_EMAIL=admin@thelook.com
ADMIN_PASSWORD=your-secure-password

# Additional admin emails (comma-separated, optional)
ADMIN_EMAILS=

# ============================================
# REQUIRED: EMAIL
# ============================================

# Resend API (booking confirmations, cancellations, reminders)
# Get your key at https://resend.com
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=onboarding@resend.dev

# ============================================
# REQUIRED: CRON
# ============================================

# Secret for authenticating the daily reminder cron job
# Used in vercel.json cron config and /api/cron/reminders
CRON_SECRET=your-cron-secret-here

# ============================================
# OPTIONAL: SECURITY
# ============================================

# Cloudflare Turnstile - bot protection for booking/contact forms
# If set, captcha verification is enforced in production
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Upstash Redis REST - distributed rate limiting
# Falls back to in-memory rate limiting if not set
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
